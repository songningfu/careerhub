      "Bash(curl -s -o /dev/null -w \"deploy.yml:                %{http_code}\\\\n\" http://127.0.0.1:8000/.github/workflows/deploy.yml)",
      "Bash(curl -s -o /dev/null -w \"crawler.yml \\(新路径\\):      %{http_code}\\\\n\" http://127.0.0.1:8000/.github/workflows/crawler.yml)"
